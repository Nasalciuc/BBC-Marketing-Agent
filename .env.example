# BBC Marketing Agent — Environment Variables
# Copy to .env and fill with real values

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (fallback)
ANTHROPIC_API_KEY=your_anthropic_key

# Unsplash
UNSPLASH_ACCESS_KEY=your_unsplash_key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=marketing

# Google Sheets
GOOGLE_SHEETS_ID=your_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# Twilio
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890
TWILIO_CONTENT_SID=HXXXXXXXXXXX

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_WEBHOOK_SECRET=random_secret_string

# WAHA
WAHA_URL=http://localhost:3000
WAHA_API_KEY=your_waha_key
WHATSAPP_GROUP_ID=120363XXXXX@g.us

# Email
RESEND_API_KEY=your_resend_key
EMAIL_FROM=noreply@buybusinessclass.com
EMAIL_TO=scaler@buybusinessclass.com

# Prefect
PREFECT_API_KEY=your_prefect_key

# BBC Branding
BBC_NAVY=#0B1829
BBC_GOLD=#C9A54E

# Environment
DEBUG=true
ENVIRONMENT=development
